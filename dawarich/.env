# Rails environment: development, staging, or production
RAILS_ENV=production

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=35875537a4751f9b8b40734d73e6fa95

# Database name
POSTGRES_DB=dawarich_production

# Database connection settings (used by Rails app)
DATABASE_HOST=dawarich_db
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=35875537a4751f9b8b40734d73e6fa95
DATABASE_NAME=dawarich_production

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis connection URL
REDIS_URL=redis://dawarich_redis:6379

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Port to expose the application on (using 3020 to avoid conflict with ntopng on 3000)
DAWARICH_APP_PORT=3020

# Application hosts (comma-separated)
APPLICATION_HOSTS=localhost,::1,127.0.0.1,dietpi.local,192.168.1.50,tracker.abiswas.duckdns.org

# Application protocol (http or https)
APPLICATION_PROTOCOL=http

# Time zone
TIME_ZONE=America/New_York

# Self-hosted flag (true for docker deployments)
SELF_HOSTED=true

# Store geodata (reverse geocoding results)
STORE_GEODATA=true

# Storage backend (local or s3)
STORAGE_BACKEND=local

# =============================================================================
# SECURITY
# =============================================================================

# Secret key base for production/staging
SECRET_KEY_BASE=8f3631223ee05792b58c611ef08fde70f5a7bee808eec2d533470945132ed289e0c37278286b5375c21d7f1fa2481be521980d8dca3fd053e040816f69726ef1

# =============================================================================
# BACKGROUND JOBS
# =============================================================================

# Sidekiq concurrency (number of threads)
BACKGROUND_PROCESSING_CONCURRENCY=5

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Prometheus / Yabeda metrics settings
PROMETHEUS_EXPORTER_ENABLED=false

# Rails logging
RAILS_LOG_TO_STDOUT=true

# Docker logging settings
LOG_MAX_SIZE=100m
LOG_MAX_FILE=5

# =============================================================================
# RESOURCE LIMITS
# =============================================================================

# CPU and memory limits for the app container
APP_CPU_LIMIT=0.50
APP_MEMORY_LIMIT=2G
